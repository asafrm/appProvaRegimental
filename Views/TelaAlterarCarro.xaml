<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="appProvaRegimental.Views.TelaAlterarCarro"
             Title="Alterar Carro">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label 
                Text="Alterar Dados do Carro"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center"/>

            <Entry
                x:Name="txtModelo"
                Placeholder="Modelo do carro"/>

            <Entry
                x:Name="txtMarca"
                Placeholder="Marca"/>

            <Entry
                x:Name="txtAno"
                Placeholder="Ano"
                Keyboard="Numeric"/>

            <Entry
                x:Name="txtPlaca"
                Placeholder="Placa"/>

            <Button
                Text="Salvar Alterações"
                Clicked="OnSalvarClicked"
                BackgroundColor="Blue"
                TextColor="White"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
