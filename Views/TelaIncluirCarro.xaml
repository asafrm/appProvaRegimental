<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="appProvaRegimental.Views.TelaIncluirPessoa"
             Title="Cadastrar Pessoa">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label
                Text="Cadastro de Pessoa"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center"/>

            <Entry
                x:Name="txtNome"
                Placeholder="Nome completo"/>

            <Entry
                x:Name="txtCpf"
                Placeholder="CPF"
                Keyboard="Numeric"/>

            <Entry
                x:Name="txtTelefone"
                Placeholder="Telefone"
                Keyboard="Telephone"/>

            <Entry
                x:Name="txtEmail"
                Placeholder="E-mail"
                Keyboard="Email"/>

            <Button
                Text="Salvar"
                Clicked="OnSalvarClicked"
                BackgroundColor="Green"
                TextColor="White"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
